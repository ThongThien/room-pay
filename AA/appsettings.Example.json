{
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-server;Port=3306;Database=your-database;User=your-user;Password=your-password;"
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",
  
  "JwtSettings": {
    "Secret": "your-secret-key-min-32-characters-long",
    "Issuer": "PayroomAPI",
    "Audience": "PayroomClient",
    "ExpirationMinutes": 1440
  }
}
