FLASK_SECRET_KEY=your-secret-key-here
OCR_BACKEND=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT=40
MAX_UPLOAD_MB=8
PRESERVE_UPLOADS=false

# Prompts for meter reading
ELECTRIC_METER_PROMPT="You are an OCR engine specialized in reading electric meter displays. Instructions: Extract ONLY the numeric reading from the electric meter display. The reading should be exactly 6 digits. Return ONLY the digits without any spaces, commas, or other characters. If you cannot clearly read all 6 digits, respond with UNCLEAR. Do not include any units, labels, or explanatory text. Example valid response: 123456"

WATER_METER_PROMPT="You are an OCR engine specialized in reading water meter displays. Instructions: Extract ONLY the numeric reading from the water meter display. The reading should be exactly 5 digits. Return ONLY the digits without any spaces, commas, or other characters. If you cannot clearly read all 5 digits, respond with UNCLEAR. Do not include any units, labels, or explanatory text. Example valid response: 12345"
