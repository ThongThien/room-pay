{
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-mysql-host;Database=InvoiceServiceDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "JwtSettings": {
    "Secret": "YourSuperSecretKeyForJWTAuthenticationThatIsAtLeast32CharactersLong",
    "Issuer": "PayroomAPI",
    "Audience": "PayroomClient",
    "ExpiresInMinutes": 1440
  },

  "ServiceApiKey": "YOUR_SERVICE_API_KEY_HERE",

  "AuthService": {
    "BaseUrl": "http://localhost:5286",
    "ApiKey": "YOUR_SERVICE_API_KEY_HERE"
  },
  
  "PropertyService": {
    "BaseUrl": "http://localhost:5018",
    "ApiKey": "YOUR_SERVICE_API_KEY_HERE"
  },
  
  "RabbitMQ": {
    "HostName": "localhost", 
    "Port": 5672,
    "UserName": "guest",      
    "Password": "guest",
    "QueueName": "notification_queue"
  },

  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": "http://localhost:3000"
  }
}
