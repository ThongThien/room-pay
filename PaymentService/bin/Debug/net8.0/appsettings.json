{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SePay": {
    "Environment": "production",
    "MerchantId": "YOUR_PRODUCTION_MERCHANT_ID",
    "SecretKey": "YOUR_PRODUCTION_SECRET_KEY",
    "CheckoutUrl": "https://pay.sepay.vn/v1/checkout/init",
    "SuccessUrl": "https://your-domain.com/api/payment/success",
    "ErrorUrl": "https://your-domain.com/api/payment/error",
    "CancelUrl": "https://your-domain.com/api/payment/cancel",
    "IpnUrl": "https://your-domain.com/api/payment/ipn"
  },
  "InvoiceService": {
    "BaseUrl": "https://your-invoice-service-url.com"
  }
}
