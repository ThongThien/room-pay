{
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-mysql-host;Port=3306;Database=reading_service_db;User=your-username;Password=your-password;"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "AWS": {
    "Profile": "default",
    "Region": "ap-southeast-1",
    "BucketName": "your-s3-bucket-name",
    "AccessKey": "YOUR_AWS_ACCESS_KEY_ID",
    "SecretKey": "YOUR_AWS_SECRET_ACCESS_KEY"
  },

  "AllowedHosts": "*",

  "JwtSettings": {
    "Secret": "YourSuperSecretKeyForJWTAuthenticationThatIsAtLeast32CharactersLong",
    "Issuer": "PayroomAPI",
    "Audience": "PayroomClient",
    "ExpiresInMinutes": 1440
  },

  "Services": {
    "InvoiceService": {
      "BaseUrl": "http://localhost:5150"
    }
  }
}