  },

  "AuthService": {
    "BaseUrl": "http://localhost:5286",
    "ApiKey": "YOUR_SERVICE_API_KEY_HERE"
  },
  "RabbitMQ": {
    "HostName": "localhost", 
    "Port": 5672,
    "UserName": "guest",      
    "Password": "guest",
