{
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-mysql-host;Port=3306;Database=reading_service_db;User=your-username;Password=your-password;"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ServiceUrls": {
    "AAService": "http://localhost:5286"
  },
  
  "AWS": {
    "Profile": "default",
    "Region": "ap-southeast-1",
