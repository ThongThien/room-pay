{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=ReadingServiceDb;user=root;password=yourpassword"
  },
  "AWS": {
    "Profile": "default",
    "Region": "ap-southeast-1",
    "BucketName": "your-s3-bucket-name",
    "AccessKey": "YOUR_AWS_ACCESS_KEY_ID",
    "SecretKey": "YOUR_AWS_SECRET_ACCESS_KEY"
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyForJWTAuthenticationThatIsAtLeast32CharactersLong",
    "Issuer": "PayroomAPI",
    "Audience": "PayroomClient",
    "ExpirationMinutes": 1440
  },
  
  "Services": {
    "InvoiceService": {
      "BaseUrl": "http://localhost:5002"
    }
  }
}
