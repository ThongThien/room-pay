generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model houses {
  Id        Int      @id @default(autoincrement())
  OwnerId   Int
  Name      String   @db.VarChar(100)
  Address   String   @db.VarChar(255)
  CreatedAt DateTime @default(now()) @db.Timestamp(0)
  users     users    @relation(fields: [OwnerId], references: [Id], onUpdate: Restrict, map: "houses_ibfk_1")
  rooms     rooms[]

  @@index([OwnerId], map: "OwnerId")
}

model invoices {
  Id              Int              @id @default(autoincrement())
  RoomId          Int
  ContractId      Int
  ReadingId       Int?
  Month           Int
  Year            Int
  Total           Decimal          @db.Decimal(12, 2)
  Status          invoices_Status? @default(unpaid)
  InvoiceUrl      String?          @db.VarChar(255)
  CreatedAt       DateTime         @default(now()) @db.Timestamp(0)
  invoiceitems    invoiceitems[]
  rooms           rooms            @relation(fields: [RoomId], references: [Id], onUpdate: Restrict, map: "invoices_ibfk_1")
  tenantcontracts tenantcontracts  @relation(fields: [ContractId], references: [Id], onUpdate: Restrict, map: "invoices_ibfk_2")
  monthlyreadings monthlyreadings? @relation(fields: [ReadingId], references: [Id], onDelete: Restrict, onUpdate: Restrict, map: "invoices_ibfk_3")

  @@index([ContractId], map: "ContractId")
  @@index([ReadingId], map: "ReadingId")
  @@index([RoomId], map: "RoomId")
}

model notifications {
  Id        Int      @id @default(autoincrement())
  UserId    Int
  Title     String   @db.VarChar(255)
  Message   String   @db.Text
  IsRead    Boolean? @default(false)
  CreatedAt DateTime @default(now()) @db.Timestamp(0)
  users     users    @relation(fields: [UserId], references: [Id], onUpdate: Restrict, map: "notifications_ibfk_1")

  @@index([UserId], map: "UserId")
}

model rooms {
  Id              Int               @id @default(autoincrement())
  HouseId         Int
  Name            String            @db.VarChar(100)
  Floor           Int
  Status          rooms_Status?     @default(vacant)
  CreatedAt       DateTime          @default(now()) @db.Timestamp(0)
  invoices        invoices[]
  monthlyreadings monthlyreadings[]
  houses          houses            @relation(fields: [HouseId], references: [Id], onUpdate: Restrict, map: "rooms_ibfk_1")
  tenantcontracts tenantcontracts[]
  tickets         tickets[]

  @@index([HouseId], map: "HouseId")
}

model tickets {
  Id          Int             @id @default(autoincrement())
  TenantId    Int
  RoomId      Int
  Title       String          @db.VarChar(255)
  Description String          @db.Text
  Status      tickets_Status? @default(pending)
  CreatedAt   DateTime        @default(now()) @db.Timestamp(0)
  users       users           @relation(fields: [TenantId], references: [Id], onUpdate: Restrict, map: "tickets_ibfk_1")
  rooms       rooms           @relation(fields: [RoomId], references: [Id], onUpdate: Restrict, map: "tickets_ibfk_2")

  @@index([RoomId], map: "RoomId")
  @@index([TenantId], map: "TenantId")
}

model users {
  Id              Int               @id @default(autoincrement())
  Name            String            @db.VarChar(100)
  Email           String            @unique(map: "Email") @db.VarChar(100)
  Phone           String?           @db.VarChar(20)
  PasswordHash    String            @db.VarChar(255)
  Role            users_Role
  Status          users_Status?     @default(active)
  CreatedAt       DateTime          @default(now()) @db.Timestamp(0)
  houses          houses[]
  notifications   notifications[]
  tenantcontracts tenantcontracts[]
  tickets         tickets[]
}

model invoiceitems {
  Id        Int      @id @default(autoincrement())
  InvoiceId Int
  Name      String   @db.VarChar(100)
  Amount    Decimal  @db.Decimal(12, 2)
  invoices  invoices @relation(fields: [InvoiceId], references: [Id], onUpdate: Restrict, map: "invoiceitems_ibfk_1")

  @@index([InvoiceId], map: "InvoiceId")
}

model monthlyreadings {
  Id            Int                     @id @default(autoincrement())
  RoomId        Int
  CycleId       Int
  ElectricOld   Int
  ElectricNew   Int
  ElectricImage String?                 @db.VarChar(255)
  WaterOld      Int
  WaterNew      Int
  WaterImage    String?                 @db.VarChar(255)
  Status        monthlyreadings_Status? @default(submitted)
  CreatedAt     DateTime                @default(now()) @db.Timestamp(0)
  invoices      invoices[]
  rooms         rooms                   @relation(fields: [RoomId], references: [Id], onUpdate: Restrict, map: "monthlyreadings_ibfk_1")
  readingcycles readingcycles           @relation(fields: [CycleId], references: [Id], onUpdate: Restrict, map: "monthlyreadings_ibfk_2")

  @@index([RoomId], map: "RoomId")
  @@index([CycleId], map: "CycleId")
}

model tenantcontracts {
  Id        Int                     @id @default(autoincrement())
  RoomId    Int
  TenantId  Int
  StartDate DateTime                @db.Date
  EndDate   DateTime?               @db.Date
  Price     Decimal                 @db.Decimal(12, 2)
  Status    tenantcontracts_Status? @default(active)
  FileUrl   String?                 @db.VarChar(255)
  CreatedAt DateTime                @default(now()) @db.Timestamp(0)
  invoices  invoices[]
  rooms     rooms                   @relation(fields: [RoomId], references: [Id], onUpdate: Restrict, map: "tenantcontracts_ibfk_1")
  users     users                   @relation(fields: [TenantId], references: [Id], onUpdate: Restrict, map: "tenantcontracts_ibfk_2")

  @@index([RoomId], map: "RoomId")
  @@index([TenantId], map: "TenantId")
}

model readingcycles {
  Id              Int                   @id @default(autoincrement())
  Month           Int
  Year            Int
  Deadline        DateTime?             @db.Date
  Status          readingcycles_Status? @default(open)
  CreatedAt       DateTime              @default(now()) @db.Timestamp(0)
  monthlyreadings monthlyreadings[]
}

enum rooms_Status {
  vacant
  occupied
  closing_soon
}

enum tickets_Status {
  pending
  processing
  done
}

enum users_Role {
  owner
  tenant
  admin
}

enum tenantcontracts_Status {
  active
  ended
}

enum users_Status {
  active
  banned
}

enum invoices_Status {
  unpaid
  pending
  paid
}

enum monthlyreadings_Status {
  pending
  submitted
  confirmed
}

enum readingcycles_Status {
  open
  closed
}
