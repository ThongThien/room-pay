generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model House {
  id        Int      @id @default(autoincrement()) @map("Id")
  ownerId   Int      @map("OwnerId")
  name      String   @map("Name") @db.VarChar(100)
  address   String   @map("Address") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  owner User   @relation(fields: [ownerId], references: [id], onUpdate: Restrict, map: "houses_ibfk_1")
  rooms Room[]

  @@index([ownerId], map: "OwnerId")
  @@map("houses")
}

model Invoice {
  id         Int             @id @default(autoincrement()) @map("Id")
  roomId     Int             @map("RoomId")
  contractId Int             @map("ContractId")
  readingId  Int?            @map("ReadingId")
  month      Int             @map("Month")
  year       Int             @map("Year")
  total      Decimal         @map("Total") @db.Decimal(12, 2)
  status     InvoiceStatus?  @default(unpaid) @map("Status")
  invoiceUrl String?         @map("InvoiceUrl") @db.VarChar(255)
  createdAt  DateTime        @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  invoiceItems    InvoiceItem[]
  room            Room              @relation(fields: [roomId], references: [id], onUpdate: Restrict, map: "invoices_ibfk_1")
  tenantContract  TenantContract    @relation(fields: [contractId], references: [id], onUpdate: Restrict, map: "invoices_ibfk_2")
  monthlyReading  MonthlyReading?   @relation(fields: [readingId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "invoices_ibfk_3")

  @@index([contractId], map: "ContractId")
  @@index([readingId], map: "ReadingId")
  @@index([roomId], map: "RoomId")
  @@map("invoices")
}

model Notification {
  id        Int      @id @default(autoincrement()) @map("Id")
  userId    Int      @map("UserId")
  title     String   @map("Title") @db.VarChar(255)
  message   String   @map("Message") @db.Text
  isRead    Boolean? @default(false) @map("IsRead")
  createdAt DateTime @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  user User @relation(fields: [userId], references: [id], onUpdate: Restrict, map: "notifications_ibfk_1")

  @@index([userId], map: "UserId")
  @@map("notifications")
}

model Room {
  id        Int         @id @default(autoincrement()) @map("Id")
  houseId   Int         @map("HouseId")
  name      String      @map("Name") @db.VarChar(100)
  floor     Int         @map("Floor")
  status    RoomStatus? @default(vacant) @map("Status")
  createdAt DateTime    @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  invoices         Invoice[]
  monthlyReadings  MonthlyReading[]
  house            House              @relation(fields: [houseId], references: [id], onUpdate: Restrict, map: "rooms_ibfk_1")
  tenantContracts  TenantContract[]
  tickets          Ticket[]

  @@index([houseId], map: "HouseId")
  @@map("rooms")
}

model Ticket {
  id          Int           @id @default(autoincrement()) @map("Id")
  tenantId    Int           @map("TenantId")
  roomId      Int           @map("RoomId")
  title       String        @map("Title") @db.VarChar(255)
  description String        @map("Description") @db.Text
  status      TicketStatus? @default(pending) @map("Status")
  createdAt   DateTime      @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  tenant User @relation(fields: [tenantId], references: [id], onUpdate: Restrict, map: "tickets_ibfk_1")
  room   Room @relation(fields: [roomId], references: [id], onUpdate: Restrict, map: "tickets_ibfk_2")

  @@index([roomId], map: "RoomId")
  @@index([tenantId], map: "TenantId")
  @@map("tickets")
}

model User {
  id           Int        @id @default(autoincrement()) @map("Id")
  name         String     @map("Name") @db.VarChar(100)
  email        String     @unique(map: "Email") @map("Email") @db.VarChar(100)
  phone        String?    @map("Phone") @db.VarChar(20)
  passwordHash String     @map("PasswordHash") @db.VarChar(255)
  role         UserRole   @map("Role")
  status       UserStatus? @default(active) @map("Status")
  createdAt    DateTime   @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  houses          House[]
  notifications   Notification[]
  tenantContracts TenantContract[]
  tickets         Ticket[]

  @@map("users")
}

model InvoiceItem {
  id        Int     @id @default(autoincrement()) @map("Id")
  invoiceId Int     @map("InvoiceId")
  name      String  @map("Name") @db.VarChar(100)
  amount    Decimal @map("Amount") @db.Decimal(12, 2)
  
  invoice Invoice @relation(fields: [invoiceId], references: [id], onUpdate: Restrict, map: "invoiceitems_ibfk_1")

  @@index([invoiceId], map: "InvoiceId")
  @@map("invoiceitems")
}

model MonthlyReading {
  id            Int                   @id @default(autoincrement()) @map("Id")
  roomId        Int                   @map("RoomId")
  cycleId       Int                   @map("CycleId")
  electricOld   Int                   @map("ElectricOld")
  electricNew   Int                   @map("ElectricNew")
  electricImage String?               @map("ElectricImage") @db.VarChar(255)
  waterOld      Int                   @map("WaterOld")
  waterNew      Int                   @map("WaterNew")
  waterImage    String?               @map("WaterImage") @db.VarChar(255)
  status        MonthlyReadingStatus? @default(submitted) @map("Status")
  createdAt     DateTime              @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  invoices      Invoice[]
  room          Room          @relation(fields: [roomId], references: [id], onUpdate: Restrict, map: "monthlyreadings_ibfk_1")
  readingCycle  ReadingCycle  @relation(fields: [cycleId], references: [id], onUpdate: Restrict, map: "monthlyreadings_ibfk_2")

  @@index([roomId], map: "RoomId")
  @@index([cycleId], map: "CycleId")
  @@map("monthlyreadings")
}

model TenantContract {
  id        Int                   @id @default(autoincrement()) @map("Id")
  roomId    Int                   @map("RoomId")
  tenantId  Int                   @map("TenantId")
  startDate DateTime              @map("StartDate") @db.Date
  endDate   DateTime?             @map("EndDate") @db.Date
  price     Decimal               @map("Price") @db.Decimal(12, 2)
  status    TenantContractStatus? @default(active) @map("Status")
  fileUrl   String?               @map("FileUrl") @db.VarChar(255)
  createdAt DateTime              @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  invoices Invoice[]
  room     Room      @relation(fields: [roomId], references: [id], onUpdate: Restrict, map: "tenantcontracts_ibfk_1")
  tenant   User      @relation(fields: [tenantId], references: [id], onUpdate: Restrict, map: "tenantcontracts_ibfk_2")

  @@index([roomId], map: "RoomId")
  @@index([tenantId], map: "TenantId")
  @@map("tenantcontracts")
}

model ReadingCycle {
  id              Int                 @id @default(autoincrement()) @map("Id")
  month           Int                 @map("Month")
  year            Int                 @map("Year")
  deadline        DateTime?           @map("Deadline") @db.Date
  status          ReadingCycleStatus? @default(open) @map("Status")
  createdAt       DateTime            @default(now()) @map("CreatedAt") @db.Timestamp(0)
  
  monthlyReadings MonthlyReading[]

  @@map("readingcycles")
}

enum RoomStatus {
  vacant
  occupied
  closing_soon

  @@map("rooms_Status")
}

enum TicketStatus {
  pending
  processing
  done

  @@map("tickets_Status")
}

enum UserRole {
  owner
  tenant
  admin

  @@map("users_Role")
}

enum TenantContractStatus {
  active
  ended

  @@map("tenantcontracts_Status")
}

enum UserStatus {
  active
  banned

  @@map("users_Status")
}

enum InvoiceStatus {
  unpaid
  pending
  paid

  @@map("invoices_Status")
}

enum MonthlyReadingStatus {
  pending
  submitted
  confirmed

  @@map("monthlyreadings_Status")
}

enum ReadingCycleStatus {
  open
  closed

  @@map("readingcycles_Status")
}
